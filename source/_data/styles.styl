// ==================================================
// 1. 全局背景图设置 (你原来的代码)
// ==================================================
body {
    background: url(/images/back.jpg);
    background-repeat: no-repeat;
    background-attachment: fixed;
    background-size: cover;
    background-position: center;
}

// ==================================================
// 2. 圆角美化设置 (新增的代码)
// ==================================================

// 顶部标题栏 (左侧) - 上圆下直
.site-brand-container {
  border-radius: 20px 20px 0 0;
}

// 侧边栏主体 (左侧) - 上直下圆
.sidebar-inner {
  border-radius: 0 0 20px 20px;
}

// 文章卡片 (右侧) - 四周圆角
.post-block {
  border-radius: 20px;
}

// 评论区 (如果有)
.comments {
  border-radius: 20px;
}

// 分页按钮
.pagination {
  border-radius: 20px;
  background: var(--card-bg-color); // 保持和卡片一致的背景
  padding: 10px;
}

// ==================================================
//  毛玻璃透明特效 (让背景图透出来)
// ==================================================

// 1. 设置侧边栏 (左侧信息栏) 的透明度
.sidebar-inner {
  // rgba(34, 34, 34, 0.7) 意思就是：深灰色，70% 不透明度
  background: rgba(34, 34, 34, 0.75) !important;
  // 这一行是灵魂：增加“磨砂玻璃”模糊效果
  backdrop-filter: blur(10px); 
}

// 2. 设置右侧文章主体区域的透明度
.content-wrap, .post-block {
  background: rgba(34, 34, 34, 0.75) !important;
  backdrop-filter: blur(10px);
}

// 3. (可选) 如果有顶部菜单栏，也一起变透明
.header-inner {
  background: rgba(34, 34, 34, 0.75) !important;
  backdrop-filter: blur(10px);
}

// 4. (可选) 让文章里的代码块背景也稍微深一点，避免混淆
.highlight {
  background: rgba(0, 0, 0, 0.6) !important;
}