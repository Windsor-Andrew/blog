// ==================================================
// Hexo NexT 自定义样式表 (styles.styl)
// ==================================================

// ==================================================
// 1. 全局背景与基础设定 (合并重构)
// ==================================================
body {
  background: url(/images/back.jpg) no-repeat fixed center;
  background-size: cover;
  background-color: #222 !important; /* 强制底色防白屏 */
  color: #eee !important;
}

// 沉浸式文本选中颜色
::selection {
  background: rgba(55, 198, 192, 0.5); /* 柔和的主题色 */
  color: #fff;
}

// ==================================================
// 2. 极致圆角美化 (Rounded Corners)
// ==================================================
.site-brand-container {
  border-radius: 20px 20px 0 0; // 顶部标题栏: 上圆下直
}

.sidebar-inner {
  border-radius: 0 0 20px 20px; // 侧边栏主体: 上直下圆
}

.post-block,
.comments {
  border-radius: 20px;          // 文章与评论区: 四周圆角
}

.pagination {
  border-radius: 20px;
  background: rgba(34, 34, 34, 0.8) !important;
  padding: 10px;
}

// ==================================================
// 3. 赛博毛玻璃透明特效 (Glassmorphism)
// ==================================================
.sidebar-inner, 
.content-wrap, 
.post-block, 
.header-inner {
  background: rgba(34, 34, 34, 0.7) !important; /* 深灰色, 70% 不透明度 */
  backdrop-filter: blur(10px);                  /* 灵魂: 磨砂玻璃模糊效果 */
  -webkit-backdrop-filter: blur(10px);          /* Safari 兼容 */
}

// 让文章里的代码块背景稍微深一点，增加层级感
.highlight {
  background: rgba(0, 0, 0, 0.6) !important;
}

// ==================================================
// 4. 强制锁定深色模式 (Force Dark Mode)
// ==================================================
:root {
  --body-bg-color: #222 !important;        /* 网页整体背景 */
  --content-bg-color: #333 !important;     /* 文章背景色 */
  --card-bg-color: #555 !important;        /* 卡片背景 */
  --text-color: #eee !important;           /* 正文文字 */
  --blockquote-color: #ccc !important;     /* 引用文字颜色 */
  --link-color: #e1e1e1 !important;        /* 链接颜色 */
  --link-hover-color: #37c6c0 !important;  /* 链接悬停颜色 */
  --menu-item-bg-color: transparent !important; /* 侧边栏文字背景防白块 */
}

// 修复浅色模式下文章标题变黑的问题
.posts-expand .post-title-link {
  color: #fff !important;
}

// ==================================================
// 5. 搜索高亮与过渡动画优化 (Search & Animations)
// ==================================================
mark.search-keyword {
  background: #ffe300 !important;  /* 抢眼的亮黄色背景 */
  color: #000 !important;          /* 强制文字纯黑，保证对比度 */
  font-weight: bold !important;
  border-radius: 4px;
}

// 强制缩短 NexT 入场动画 (配合 Pjax 极速响应)
.use-motion .post-block,
.use-motion .pagination,
.use-motion .comments,
.use-motion .sidebar {
  animation-duration: 0.25s !important; 
}

// 加速全局鼠标悬停渐变反应
*, *:before, *:after {
  transition-duration: 0.15s !important;
}

// ==================================================
// 6. 极简滚动条定制 (Custom Scrollbar)
// ==================================================
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}
::-webkit-scrollbar-thumb {
  background: #555;
  border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
  background: #37c6c0;
}
::-webkit-scrollbar-track {
  background: transparent;
}

// ==================================================
// 7. 第三方组件透明度适配 (APlayer 等)
// ==================================================
.aplayer {
  background: rgba(0, 0, 0, 0.2) !important;
  border-radius: 8px !important;
  box-shadow: none !important;
  color: #eee !important;
}
.aplayer .aplayer-list ol li:hover,
.aplayer .aplayer-list ol li.aplayer-list-light {
  background: rgba(255, 255, 255, 0.1) !important;
}
.aplayer .aplayer-info .aplayer-controller .aplayer-time {
  color: #ccc !important;
}

