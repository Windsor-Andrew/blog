<script>
  (function() {
    /**
     * 功能 1：高能搜索关键词自动定位 (破解弹窗锁死版)
     */
    function scrollToSearchKeyword() {
      // 过滤非文章页
      if (window.location.pathname === '/' || document.querySelector('.post-button')) return;

      let count = 0;
      // 开启“雷达”，每 200ms 扫描一次高亮词
      let scrollTimer = setInterval(function() {
        const keyword = document.querySelector('mark.search-keyword');

        if (keyword) {
          clearInterval(scrollTimer); // 抓到目标，关掉雷达

          // 🌟 核心破局点：强制解除搜索框残留的“滚动锁定” 🌟
          document.body.style.overflow = '';
          document.body.classList.remove('search-active');
          document.documentElement.style.overflow = '';

          // 解锁后稍等 300 毫秒，让浏览器喘口气，然后发起冲锋
          setTimeout(() => {
            const targetY = keyword.getBoundingClientRect().top + window.scrollY - (window.innerHeight / 3);
            window.scrollTo({ top: targetY, behavior: 'smooth' });
            console.log('🎯 破除滚动锁，已成功滑向关键词！');
          }, 300);
        }

        // 找了 20 次（4秒）还没找到，说明文章里没这个词，直接放弃
        if (++count > 20) clearInterval(scrollTimer);
      }, 200);
    }

    /**
     * 功能 2：Giscus 评论区动态加载 (完美适配 Pjax)
     */
    function initGiscus() {
      const path = window.location.pathname;
      const isList = path === '/' || path.startsWith('/page/') || path.startsWith('/archives/') || 
                     path.startsWith('/categories/') || path.startsWith('/tags/') || 
                     document.querySelector('.post-button');
      
      if (isList || document.getElementById('hbe-template')) return;

      const container = document.querySelector('.post-block') || document.querySelector('.comments');
      if (!container) return;

      const oldFrame = document.querySelector('.giscus-frame');
      if (oldFrame) oldFrame.remove();

      let gDiv = document.getElementById('giscus-container');
      if (!gDiv) {
        gDiv = document.createElement('div');
        gDiv.id = 'giscus-container';
        gDiv.style.marginTop = '40px';
        container.appendChild(gDiv);
      }

      const script = document.createElement('script');
      script.src = 'https://giscus.app/client.js';
      script.setAttribute('data-repo', 'Windsor-Andrew/blog');
      script.setAttribute('data-repo-id', 'R_kgDORDYTUg');
      script.setAttribute('data-category', 'Announcements');
      script.setAttribute('data-category-id', 'DIC_kwDORDYTUs4C1wm4');
      script.setAttribute('data-mapping', 'pathname');
      script.setAttribute('data-reactions-enabled', '1');
      script.setAttribute('data-theme', 'dark');
      script.setAttribute('data-lang', 'zh-CN');
      script.crossOrigin = 'anonymous';
      script.async = true;
      gDiv.appendChild(script);
    }

    function runAll() {
      scrollToSearchKeyword();
      initGiscus();
    }

    // 监听正常刷新加载
    window.addEventListener('DOMContentLoaded', runAll);
    // 监听 Pjax 无刷新加载 (使用 complete 确保所有 DOM 替换完毕)
    document.addEventListener('pjax:complete', runAll);
    document.addEventListener('pjax:success', runAll);
  })();
</script>