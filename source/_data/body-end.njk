<script>
  /**
   * 功能 1：高能搜索关键词自动定位 (Pjax + Motion 兼容版)
   */
  function scrollToSearchKeyword() {
    // 只有路径里包含文章内容时才执行，排除首页
    if (window.location.pathname === '/' || document.querySelector('.post-button')) return;

    let retryTimes = 0;
    const maxRetry = 15; // 最多等 3 秒

    function checkAndScroll() {
      const keyword = document.querySelector('mark.search-keyword');
      
      if (keyword) {
        // --- 核心修改：增加 800ms 延迟 ---
        // 这一步是为了死等 NexT 的 Motion (入场动画) 播完
        // 否则动画过程中的坐标计算永远是错的
        setTimeout(() => {
          const rect = keyword.getBoundingClientRect();
          const targetY = rect.top + window.pageYOffset - (window.innerHeight / 3);
          
          window.scrollTo({
            top: targetY,
            behavior: 'smooth'
          });
          console.log('🎯 搜索定位：动画结束，已精准跳转');
        }, 800); 
      } else if (retryTimes < maxRetry) {
        retryTimes++;
        setTimeout(checkAndScroll, 200);
      }
    }

    // Pjax 跳转后，给系统一点点启动时间
    setTimeout(checkAndScroll, 500);
  }

  /**
   * 功能 2：Giscus 评论区动态加载 (列表页过滤)
   */
  function initGiscus() {
    const path = window.location.pathname;
    const isList = path === '/' || path.startsWith('/page/') || path.startsWith('/archives/') || 
                   path.startsWith('/categories/') || path.startsWith('/tags/') || 
                   document.querySelector('.post-button');
    
    if (isList || document.getElementById('hbe-template')) return;

    const container = document.querySelector('.post-block') || document.querySelector('.comments');
    if (!container) return;

    // 防止 Pjax 导致的重影
    if (document.querySelector('.giscus-frame')) {
      document.querySelector('.giscus-frame').remove();
    }

    let gDiv = document.getElementById('giscus-container');
    if (!gDiv) {
      gDiv = document.createElement('div');
      gDiv.id = 'giscus-container';
      gDiv.style.marginTop = '40px';
      container.appendChild(gDiv);
    }

    const script = document.createElement('script');
    script.src = 'https://giscus.app/client.js';
    script.setAttribute('data-repo', 'Windsor-Andrew/blog');
    script.setAttribute('data-repo-id', 'R_kgDORDYTUg');
    script.setAttribute('data-category', 'Announcements');
    script.setAttribute('data-category-id', 'DIC_kwDORDYTUs4C1wm4');
    script.setAttribute('data-mapping', 'pathname');
    script.setAttribute('data-reactions-enabled', '1');
    script.setAttribute('data-theme', 'dark');
    script.setAttribute('data-lang', 'zh-CN');
    script.crossOrigin = 'anonymous';
    script.async = true;
    gDiv.appendChild(script);
  }

  function runAllEffects() {
    scrollToSearchKeyword();
    initGiscus();
  }

  // 监听初次加载
  document.addEventListener('DOMContentLoaded', runAllEffects);
  // 关键：监听 Pjax 完成事件
  document.addEventListener('pjax:success', runAllEffects);
</script>